# =====================================================================
#  BU DOSYAYI ".env" OLARAK KOPYALAYIN ve kendi anahtarlarınızı girin.
#  .env dosyasını ASLA kimseyle paylaşmayın, Claude'a da göndermeyin.
# =====================================================================

# --- Binance API anahtarları ---
# ÖNEMLİ: Binance'te anahtar oluştururken SADECE şu izinleri verin:
#   [x] Enable Reading
#   [x] Enable Spot & Margin Trading   (gerekiyorsa)
#   [ ] Enable Withdrawals  <-- BUNU ASLA AÇMAYIN
BINANCE_API_KEY=buraya_api_key
BINANCE_API_SECRET=buraya_secret

# --- Çalışma modu ---
# true  = Binance TESTNET (sahte para, güvenli test ortamı)
# false = GERÇEK Binance hesabı (gerçek para!)
USE_TESTNET=true

# --- Canlı işlem kilidi (çift güvenlik) ---
# Bot varsayılan olarak DRY-RUN'dır: emir göndermez, sadece simüle eder.
# Gerçek emir göndermek için AŞAĞIDAKİ İKİSİNİ DE true yapmalısınız:
LIVE_TRADING=false
I_UNDERSTAND_THE_RISK=false

# --- Telegram bildirimleri (sinyal botu) ---
# @BotFather'dan bot oluşturup token alın. chat id için: python -m src.notifier
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
